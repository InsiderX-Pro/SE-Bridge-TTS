{
  "paper": {
    "title": "Bridging the Stability-Expressivity Gap: Synthetic Data Scaling and Preference Alignment for Low-Resource Spoken Language Models",
    "shortTitle": "SE-Bridge-TTS",
    "venue": "ICML 2026",
    "authors": [
      "Yizhong Geng",
      "Yanliang Li",
      "Jinghan Yang",
      "Tianhan Jiang",
      "Boxun An",
      "Ya Li",
      "Xiaoyu Shen"
    ],
    "paperUrl": "https://arxiv.org/abs/2605.27383",
    "codeUrl": "https://github.com/InsiderX-Pro/SE-Bridge-TTS"
  },
  "figures": [
    {
      "id": "dgsa",
      "title": "Disentanglement-Guided Self-Alignment",
      "src": "assets/figures/dgsa.png",
      "caption": "DGSA uses prosody-timbre separation in flow-matching SLMs to construct preference pairs that recover expressivity while preserving speaker identity."
    },
    {
      "id": "tdsc",
      "title": "Temperature-Driven Self-Critique",
      "src": "assets/figures/tdsc.png",
      "caption": "TDSC samples across conservative, balanced, and exploratory temperatures, then filters candidates to bootstrap low-resource synthesis without authentic anchors."
    }
  ],
  "results": [
    {
      "label": "Thai standard TTS",
      "metric": "NMOS",
      "value": "4.51",
      "note": "DGSA achieves the strongest naturalness score among tested systems."
    },
    {
      "label": "Lao standard TTS",
      "metric": "WER / NMOS",
      "value": "29.8 / 4.53",
      "note": "TDSC improves both intelligibility and naturalness in a pure-synthetic setting."
    },
    {
      "label": "Thai zero-shot cloning",
      "metric": "SIM / SMOS",
      "value": "0.84 / 4.51",
      "note": "The model surpasses ElevenLabs-v3 on speaker similarity and perceived identity."
    },
    {
      "label": "Lao zero-shot cloning",
      "metric": "SIM / SMOS",
      "value": "0.81 / 4.32",
      "note": "The first demonstrated zero-shot voice cloning capability for Lao in this setup."
    }
  ],
